generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  phone          String?
  role           UserRole  @default(OWNER)
  createdAt      DateTime  @default(now())
  favoriteSalons String[]  @default([])
  bookings       Booking[] @relation("UserBookings")
  reviews        Review[]  @relation("UserReviews")
  salons         Salon[]   @relation("UserSalons")
}

model Salon {
  id           String        @id @default(cuid())
  name         String
  description  String?
  address      String?
  phone        String?
  email        String?
  website      String?
  instagram    String?
  logo         String?
  photos       String[]
  workingHours Json?
  ownerId      String
  createdAt    DateTime      @default(now())
  categoryIds  Int[]
  inviteCodeId String?
  bookings     Booking[]
  reviews      Review[]
  inviteCode   InviteCode?   @relation("InviteCodeUsage", fields: [inviteCodeId], references: [id])
  owner        User          @relation("UserSalons", fields: [ownerId], references: [id])
  services     Service[]
  smsUsage     SmsUsage[]
  staff        Staff[]
  subscription Subscription?
  TimeBlock    TimeBlock[]
}

model Staff {
  id          String           @id @default(cuid())
  name        String
  accessLevel StaffAccessLevel @default(EMPLOYEE)
  email       String?
  phone       String?
  salonId     String
  bookings    Booking[]
  salon       Salon            @relation(fields: [salonId], references: [id])
  TimeBlock   TimeBlock[]
  RescheduledTimeBlocks TimeBlock[] @relation("TimeBlockReschedule")
  services    Service[]        @relation("StaffServices")

  @@unique([name, salonId])
}

model ServiceCategory {
  id               Int                @id @default(autoincrement())
  nameEn           String             @unique @map("name_en")
  nameVn           String             @unique @map("name_vn")
  nameRu           String             @unique @map("name_ru")
  services         Service[]
  service_synonyms service_synonyms[]

  @@map("service_categories")
}

model Service {
  id                String           @id @default(cuid())
  name              String
  description       String?
  // Multilingual fields (optional)
  nameEn            String?
  nameVi            String?
  nameRu            String?
  descriptionEn     String?
  descriptionVi     String?
  descriptionRu     String?
  duration          Int
  price             Float
  salonId           String
  categoryId        String?
  serviceCategoryId Int?
  serviceGroupId    String?
  bookings          Booking[]
  salon             Salon            @relation(fields: [salonId], references: [id])
  serviceCategory   ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])
  serviceGroup      ServiceGroup?    @relation(fields: [serviceGroupId], references: [id])
  staff             Staff[]          @relation("StaffServices")

  @@unique([name, salonId])
}

model ServiceGroup {
  id          String    @id @default(cuid())
  salonId     String
  name        String
  description String?
  position    Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  services    Service[]

  @@index([salonId, position])
}

model Booking {
  id           String        @id @default(cuid())
  salonId      String
  userId       String
  serviceId    String
  staffId      String?
  status       BookingStatus @default(PENDING)
  notes        String?
  createdAt    DateTime      @default(now())
  dateTime     DateTime
  reminderSent Boolean       @default(false)
  salon        Salon         @relation(fields: [salonId], references: [id])
  service      Service       @relation(fields: [serviceId], references: [id])
  staff        Staff?        @relation(fields: [staffId], references: [id])
  user         User          @relation("UserBookings", fields: [userId], references: [id])
  reviews      Review[]      @relation("BookingReviews")
}

model Review {
  id        String   @id @default(cuid())
  salonId   String
  userId    String
  bookingId String?
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  booking   Booking? @relation("BookingReviews", fields: [bookingId], references: [id])
  salon     Salon    @relation(fields: [salonId], references: [id])
  user      User     @relation("UserReviews", fields: [userId], references: [id])

  @@unique([userId, salonId, bookingId])
}

model Subscription {
  id              String             @id @default(cuid())
  salonId         String             @unique
  type            SubscriptionType   @default(BASIC)
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime
  endDate         DateTime?
  nextPaymentDate DateTime?
  amount          Float
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  salon           Salon              @relation(fields: [salonId], references: [id])
}

model SmsUsage {
  id        String   @id @default(cuid())
  salonId   String
  sent      Int      @default(0)
  balance   Int      @default(0)
  month     Int
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  salon     Salon    @relation(fields: [salonId], references: [id])

  @@unique([salonId, month, year])
}

model service_synonyms {
  id                 Int              @id @default(autoincrement())
  category_id        Int?
  keyword            String           @db.VarChar(100)
  language           String?          @default("en") @db.VarChar(2)
  weight             Decimal?         @default(1.0) @db.Decimal(3, 2)
  created_at         DateTime?        @default(now()) @db.Timestamp(6)
  service_categories ServiceCategory? @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([category_id, keyword, language])
  @@index([category_id], map: "idx_service_synonyms_category")
  @@index([keyword], map: "idx_service_synonyms_keyword")
}

model InviteCode {
  id          String           @id @default(cuid())
  code        String           @unique
  maxUses     Int              @default(1)
  usedCount   Int              @default(0)
  source      String?
  note        String?
  status      InviteCodeStatus @default(ACTIVE)
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime         @default(now())
  usedBy      Salon[]          @relation("InviteCodeUsage")

  @@index([code])
  @@index([status])
}

model TimeBlock {
  id                  String         @id
  salonId             String
  staffId             String?
  type                TimeBlockType
  reason              String
  startDate           DateTime
  endDate             DateTime
  notes               String?
  conflictAction      ConflictAction @default(CANCEL)
  rescheduleStaffId   String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime
  Salon               Salon          @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Staff               Staff?         @relation(fields: [staffId], references: [id], onUpdate: NoAction)
  RescheduleStaff     Staff?         @relation("TimeBlockReschedule", fields: [rescheduleStaffId], references: [id], onUpdate: NoAction)

  @@index([salonId])
  @@index([staffId])
  @@index([startDate, endDate])
}

enum UserRole {
  OWNER
  ADMIN
  CLIENT
}

enum StaffAccessLevel {
  ADMIN
  EMPLOYEE
}

enum BookingStatus {
  CONFIRMED
  CANCELED
  COMPLETED
  PENDING
}

enum SubscriptionType {
  BASIC
  ENTERPRISE
  FREEMIUM
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  EXPIRED
}

enum InviteCodeStatus {
  ACTIVE
  EXPIRED
  REVOKED
  EXHAUSTED
}

enum ConflictAction {
  KEEP
  RESCHEDULE
  CANCEL
}

enum TimeBlockType {
  TIME_OFF
  BUSY
  CLOSURE
}
