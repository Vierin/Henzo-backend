generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  phone     String?   // Add phone for clients
  role      UserRole  @default(OWNER)
  salons    Salon[]   @relation("UserSalons")
  bookings  Booking[] @relation("UserBookings") // Add bookings relation for clients
  reviews   Review[]  @relation("UserReviews") // Add reviews relation for clients
  createdAt DateTime  @default(now())
}

model Salon {
  id            String    @id @default(cuid())
  name          String
  description   String?   // Salon description
  address       String?
  phone         String?
  email         String?   // Salon email
  website       String?   // Salon website URL
  instagram     String?   // Instagram handle
  logo          String?   // Supabase file path to salon logo
  photos        String[]  // Array of Supabase file paths to salon photos (max 3)
  workingHours  Json?     // Store working hours as JSON
  owner         User      @relation("UserSalons", fields: [ownerId], references: [id])
  ownerId       String
  staff         Staff[]
  services      Service[]
  categories    Category[]
  bookings      Booking[]
  reviews       Review[]
  subscription  Subscription?
  smsUsage      SmsUsage[]
  createdAt     DateTime  @default(now())
}

model Staff {
  id          String        @id @default(cuid())
  name        String
  accessLevel StaffAccessLevel @default(EMPLOYEE)
  email       String?
  phone       String?
  salon       Salon         @relation(fields: [salonId], references: [id])
  salonId     String
  services    Service[]     @relation("StaffServices")
  bookings    Booking[]
  
  @@unique([name, salonId])
}

model Service {
  id          String    @id @default(cuid())
  name        String
  description String?
  duration    Int
  price       Float
  salon       Salon     @relation(fields: [salonId], references: [id])
  salonId     String
  category    Category? @relation(fields: [categoryId], references: [id])
  categoryId  String?
  staff       Staff[]   @relation("StaffServices")
  bookings    Booking[]

  @@unique([name, salonId])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  salon     Salon     @relation(fields: [salonId], references: [id])
  salonId   String
  services  Service[]
  createdAt DateTime  @default(now())

  @@unique([name, salonId])
}


model Booking {
  id        String         @id @default(cuid())
  salon     Salon          @relation(fields: [salonId], references: [id])
  salonId   String
  user      User           @relation("UserBookings", fields: [userId], references: [id])
  userId    String
  service   Service        @relation(fields: [serviceId], references: [id])
  serviceId String
  staff     Staff?         @relation(fields: [staffId], references: [id])
  staffId   String?
  time      DateTime
  status    BookingStatus  @default(PENDING)
  notes     String?
  createdAt DateTime       @default(now())
  reviews   Review[]       @relation("BookingReviews")
}

model Review {
  id        String   @id @default(cuid())
  salon     Salon    @relation(fields: [salonId], references: [id])
  salonId   String
  user      User     @relation("UserReviews", fields: [userId], references: [id])
  userId    String
  booking   Booking? @relation("BookingReviews", fields: [bookingId], references: [id])
  bookingId String?
  rating    Int      // 1-5 stars
  comment   String?
  createdAt DateTime @default(now())

  @@unique([userId, salonId, bookingId]) // One review per booking per user
}

enum UserRole {
  OWNER
  ADMIN
  CLIENT
}

enum StaffAccessLevel {
  ADMIN      // Salon admin with full access
  EMPLOYEE   // Regular employee with limited access
}

model Subscription {
  id              String            @id @default(cuid())
  salon           Salon             @relation(fields: [salonId], references: [id])
  salonId         String            @unique
  type            SubscriptionType  @default(BASIC)
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime
  endDate         DateTime?
  nextPaymentDate DateTime?
  amount          Float
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model SmsUsage {
  id          String   @id @default(cuid())
  salon       Salon    @relation(fields: [salonId], references: [id])
  salonId     String
  sent        Int      @default(0)
  balance     Int      @default(0)
  month       Int      // 1-12
  year        Int      // e.g., 2024
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([salonId, month, year])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELED
}

enum SubscriptionType {
  BASIC
  PREMIUM
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  EXPIRED
}


