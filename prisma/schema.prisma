generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Booking {
  id                     String        @id @default(cuid())
  salonId                String
  userId                 String
  serviceId              String
  staffId                String?
  status                 BookingStatus @default(PENDING)
  notes                  String?
  createdAt              DateTime      @default(now())
  dateTime               DateTime
  reminderSent           Boolean       @default(false)
  remindersSentIntervals Json?         @default("[]")
  Salon                  Salon         @relation(fields: [salonId], references: [id])
  Service                Service       @relation(fields: [serviceId], references: [id])
  Staff                  Staff?        @relation(fields: [staffId], references: [id])
  User                   User          @relation(fields: [userId], references: [id])
  Review                 Review[]

  @@index([salonId, status, dateTime])
  @@index([userId, dateTime])
  @@index([dateTime])
  @@index([salonId, createdAt])
  @@index([status, dateTime]) // P3: Для быстрого поиска по статусу и дате
  @@index([salonId, dateTime, status]) // P3: Составной индекс для фильтрации
  @@index([userId, status, dateTime]) // P2: Для быстрого поиска клиентских бронирований по статусу
}

model PendingBooking {
  id          String   @id @default(cuid())
  token       String   @unique
  email       String
  bookingData Json
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
  @@index([token])
}

model PendingBusinessRegistration {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  name      String
  password  String   @default("") // Hashed password or userId (temporary)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
  @@index([token])
}

model Review {
  id        String   @id @default(cuid())
  salonId   String
  userId    String
  bookingId String?
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  Booking   Booking? @relation(fields: [bookingId], references: [id])
  Salon     Salon    @relation(fields: [salonId], references: [id])
  User      User     @relation(fields: [userId], references: [id])

  @@unique([userId, salonId, bookingId])
  @@index([salonId, createdAt])
  @@index([salonId, rating])
}

model Salon {
  id               String        @id @default(cuid())
  name             String
  description      String?
  address          String?
  phone            String?
  email            String?
  website          String?
  instagram        String?
  logo             String?
  photos           String[]
  workingHours     Json?
  reminderSettings Json?         @default("{\"intervals\":[24]}")
  ownerId          String
  createdAt        DateTime      @default(now())
  categoryIds      Int[]
  latitude         Float?
  longitude        Float?
  descriptionEn    String?
  descriptionVi    String?
  descriptionRu    String?
  timezone         String         @default("Asia/Ho_Chi_Minh") // IANA timezone identifier
  Booking          Booking[]
  Review           Review[]
  User             User          @relation(fields: [ownerId], references: [id])
  Service          Service[]
  SmsUsage         SmsUsage[]
  Staff            Staff[]
  Subscription     Subscription?
  TimeBlock        TimeBlock[]

  @@index([latitude, longitude])
  @@index([ownerId, createdAt])
  @@index([createdAt])
}

model Service {
  id                 String              @id @default(cuid())
  name               String
  description        String?
  duration           Int
  price              Float
  salonId            String
  categoryId         String?
  serviceCategoryId  Int?
  nameEn             String?
  nameVi             String?
  nameRu             String?
  descriptionEn      String?
  descriptionVi      String?
  descriptionRu      String?
  serviceGroupId     String?
  Booking            Booking[]
  Salon              Salon               @relation(fields: [salonId], references: [id])
  service_categories service_categories? @relation(fields: [serviceCategoryId], references: [id])
  ServiceGroup       ServiceGroup?       @relation(fields: [serviceGroupId], references: [id])
  Staff              Staff[]             @relation("StaffServices")

  @@unique([name, salonId])
}

model ServiceGroup {
  id        String    @id @default(cuid())
  salonId   String
  name      String
  nameEn    String?
  nameVi    String?
  nameRu    String?
  position  Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  Service   Service[]

  @@index([salonId, position])
}

model SmsUsage {
  id        String   @id
  salonId   String
  sent      Int      @default(0)
  balance   Int      @default(0)
  month     Int
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime
  Salon     Salon    @relation(fields: [salonId], references: [id])

  @@unique([salonId, month, year])
}

model Staff {
  id                                           String           @id @default(cuid())
  name                                         String
  accessLevel                                  StaffAccessLevel @default(EMPLOYEE)
  email                                        String?
  phone                                        String?
  salonId                                      String
  Booking                                      Booking[]
  Salon                                        Salon            @relation(fields: [salonId], references: [id])
  TimeBlock_TimeBlock_rescheduleStaffIdToStaff TimeBlock[]      @relation("TimeBlock_rescheduleStaffIdToStaff")
  TimeBlock_TimeBlock_staffIdToStaff           TimeBlock[]      @relation("TimeBlock_staffIdToStaff")
  Service                                      Service[]        @relation("StaffServices")

  @@unique([name, salonId])
}

model Subscription {
  id              String             @id @default(cuid())
  salonId         String             @unique
  type            SubscriptionType   @default(BASIC)
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime
  endDate         DateTime?
  nextPaymentDate DateTime?
  amount          Float
  createdAt       DateTime           @default(now())
  updatedAt       DateTime
  Salon           Salon              @relation(fields: [salonId], references: [id])
}

model TimeBlock {
  id                                       String         @id
  salonId                                  String
  staffId                                  String?
  type                                     TimeBlockType
  reason                                   String
  startDate                                DateTime
  endDate                                  DateTime
  notes                                    String?
  conflictAction                           ConflictAction @default(CANCEL)
  createdAt                                DateTime       @default(now())
  updatedAt                                DateTime
  rescheduleStaffId                        String?
  Staff_TimeBlock_rescheduleStaffIdToStaff Staff?         @relation("TimeBlock_rescheduleStaffIdToStaff", fields: [rescheduleStaffId], references: [id], onUpdate: NoAction)
  Salon                                    Salon          @relation(fields: [salonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Staff_TimeBlock_staffIdToStaff           Staff?         @relation("TimeBlock_staffIdToStaff", fields: [staffId], references: [id], onUpdate: NoAction)

  @@index([salonId])
  @@index([staffId])
  @@index([startDate, endDate])
}

model User {
  id               String      @id @default(cuid())
  email            String      @unique
  name             String?
  phone            String?
  role             UserRole    @default(OWNER)
  /// Indicates that the user was created implicitly (e.g. via booking magic link)
  /// and has not yet completed full account registration.
  isGuest          Boolean     @default(false)
  createdAt        DateTime    @default(now())
  favoriteSalons   String[]    @default([])
  telegramId       String?     @unique
  telegramUsername String?
  telegramPhotoUrl String?
  Booking          Booking[]
  pushTokens       PushToken[]
  Review           Review[]
  Salon            Salon[]
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String
  language  String?  @default("en")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([isActive])
}

model service_categories {
  id      Int       @id @default(autoincrement())
  name_en String    @unique
  name_vn String    @unique
  name_ru String    @unique
  Service Service[]
}

model RecommendedService {
  id         Int      @id @default(autoincrement())
  nameEn     String
  nameVi     String
  nameRu     String
  categoryId Int?
  priority   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([nameEn, nameVi, nameRu])
  @@index([priority])
  @@index([categoryId])
}

enum BookingStatus {
  CONFIRMED
  CANCELED
  COMPLETED
  PENDING
  NOSHOW
}

enum ConflictAction {
  KEEP
  CANCEL
  RESCHEDULE
}

enum StaffAccessLevel {
  ADMIN
  EMPLOYEE
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  EXPIRED
}

enum SubscriptionType {
  BASIC
  ENTERPRISE
  FREEMIUM
}

enum TimeBlockType {
  TIME_OFF
  BUSY
  CLOSURE
}

enum UserRole {
  OWNER
  ADMIN
  CLIENT
}
